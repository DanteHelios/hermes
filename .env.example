# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash

# Google Places
GOOGLE_PLACES_API_KEY=your-places-api-key

# Sender defaults (also in config table)
SENDER_NAME=Enrique
SENDER_TITLE=CTO, Helios Marketing

# Logging
LOG_LEVEL=INFO

# AgentMail — https://agentmail.to
AGENTMAIL_API_KEY=am_xxx...
AGENTMAIL_INBOX_USERNAME=outreach
# Leave AGENTMAIL_INBOX_DOMAIN unset to use the default @agentmail.to domain.
# Set to your custom domain (e.g. heliosmarketing.org) once you upgrade to
# a paid plan and verify the domain in the AgentMail console.
AGENTMAIL_INBOX_DOMAIN=

# FastAPI / Auth
DASHBOARD_PASSWORD=change-me-before-deploy
JWT_SECRET=generate-a-random-32-char-string
JWT_EXPIRY_DAYS=30
API_HOST=0.0.0.0
API_PORT=8000
# Regex of allowed CORS origins. Default allows localhost only.
# In production set to match your frontend domain, e.g.:
# CORS_ORIGIN_REGEX=^https://(hermes(-[a-z0-9]+)?\.vercel\.app|yourdomain\.com)$
CORS_ORIGIN_REGEX=

# Runtime environment. "dev" tolerates missing Calendly signatures with a
# warning. "prod" enforces them and fails startup if the secret is unset.
APP_ENV=dev

# System-wide daily send ceiling (across all campaigns). The campaign runner
# refuses to send once today's total outbound reaches this number.
HERMES_MAX_DAILY_SENDS=200

# Calendly — webhook signature verification
# Copy the "Signing key" from your Calendly webhook subscription.
# Required when APP_ENV=prod; optional (warning-only) when APP_ENV=dev.
CALENDLY_WEBHOOK_SECRET=

# Firecrawl — optional, used as fallback scraper for JS-rendered sites
# where HTTP-only scraping finds zero emails. Leave blank to disable.
# https://firecrawl.dev
FIRECRAWL_API_KEY=

# Unipile — LinkedIn messaging provider. https://unipile.com
# DSN is the per-account host (e.g. api3.unipile.com:13344), issued when
# you connect a LinkedIn account through Unipile's hosted-auth flow.
# Leave blank to disable the LinkedIn channel; the email pipeline keeps
# working unchanged.
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_ACCOUNT_ID=

# LinkedIn cadence: days after a 'sent' email with no reply before we
# escalate that lead to a LinkedIn invite. Account-safety ceilings keep
# us well under LinkedIn's ~100/week invite limit.
LINKEDIN_FOLLOWUP_DAYS=4
LINKEDIN_MAX_DAILY_SENDS=50
LINKEDIN_DRAFT_PER_TICK=5
LINKEDIN_SEND_PER_TICK=5
